DATABASE_URL=sqlite+aiosqlite:///./researchlens.db
# For PostgreSQL (cloud): DATABASE_URL=postgresql://user:password@host:5432/researchlens

REDIS_URL=
# For Redis cloud: REDIS_URL=redis://user:password@host:6379

EMBEDDING_MODEL=allenai/specter2_base

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
MAX_FILES=50

MIN_CLUSTER_SIZE=3
WEIGHT_STRUCT=0.40
WEIGHT_SEM=0.35
WEIGHT_TEMP=0.25

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
